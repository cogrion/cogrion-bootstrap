{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TofuStateBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:ListBucket",
        "s3:PutBucketEncryption",
        "s3:GetBucketEncryption",
        "s3:PutBucketPublicAccessBlock",
        "s3:GetBucketPublicAccessBlock"
      ],
      "Resource": [
        "arn:aws:s3:::${cogrion_workspace_id}*",
        "arn:aws:s3:::${cogrion_workspace_id}*/*"
      ]
    },
    {
      "Sid": "EksDescribeAndNodegroups",
      "Effect": "Allow",
      "Action": [
        "eks:DescribeCluster",
        "eks:DescribeNodegroup",
        "eks:ListNodegroups",
        "eks:CreateNodegroup",
        "eks:DeleteNodegroup",
        "eks:TagResource"
      ],
      "Resource": [
        "arn:aws:eks:${aws_region}:${aws_account_id}:cluster/${cluster_name}",
        "arn:aws:eks:${aws_region}:${aws_account_id}:nodegroup/${cluster_name}/*/*"
      ]
    },
    {
      "Sid": "Ec2DescribeReadOnly",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeSubnets",
        "ec2:DescribeRouteTables",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeLaunchTemplates",
        "ec2:DescribeLaunchTemplateVersions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Ec2NodeGroupProvisioning",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSecurityGroup",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:CreateLaunchTemplate",
        "ec2:CreateTags"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IamRoleAndPolicyProvisioning",
      "Effect": "Allow",
      "Action": [
        "iam:GetRole",
        "iam:CreateRole",
        "iam:UpdateAssumeRolePolicy",
        "iam:AttachRolePolicy",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicyVersions",
        "iam:CreatePolicy",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion"
      ],
      "Resource": [
        "arn:aws:iam::${aws_account_id}:role/*",
        "arn:aws:iam::${aws_account_id}:policy/*"
      ]
    },
    {
      "Sid": "PassNodeRoleToEks",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::${aws_account_id}:role/*-node-role"
    },
    {
      "Sid": "CallerIdentity",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    }
  ]
}