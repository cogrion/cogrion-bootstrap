region = "us-east-1"

cogrion_account_id   = "my-account"
cogrion_workspace_id = "w-my-workspace"

# Self-deploy mode (default): leave these unset, use your own credentials.
# Assume-role mode: uncomment and set to the role Cogrion should assume.
# assume_role_arn          = "arn:aws:iam::123456789012:role/cogrion-provisioning"
# assume_role_session_name = "cogrion-automation"
# assume_role_external_id  = ""

vpc_name = "my-cogrion-workspace"
vpc_cidr = "10.0.0.0/16"
az_count = 2

public_subnets     = ["10.0.0.0/24", "10.0.1.0/24"]
private_subnets    = ["10.0.10.0/24", "10.0.11.0/24"]
db_private_subnets = ["10.0.20.0/24", "10.0.21.0/24"]

tags = {
  Environment = "sandbox"
  ManagedBy   = "terraform"
}

# --- EKS cluster -------------------------------------------------------
# All of these have defaults (see variables.tf) — shown here for discoverability.
eks_kubernetes_version              = "1.36"
eks_cluster_endpoint_public_access  = true # fine for sandbox; set false once private access is confirmed
kms_key_admin_roles                 = []

# One node group per logical workload — "system" for cluster-wide addons,
# "observability" as an example of a dedicated, stateful (single-AZ) group
# matching what ObservabilityConfig.byoNodegroup expects if you adopt it.
eks_managed_node_groups = {
  system = {
    description    = "System EKS managed node group"
    min_size       = 1
    max_size       = 3
    desired_size   = 1
    instance_types = ["t3.large"]
    disk_size      = 100
    labels = {
      nodegroup     = "system" # matches nodeSelector.nodegroup=system set on the addons in eks-cluster.tf
      WorkerType    = "ON_DEMAND"
      NodeGroupType = "system"
    }
  }
  observability = {
    description    = "Dedicated node group for the observability stack"
    stateful       = true
    min_size       = 1
    max_size       = 2
    desired_size   = 1
    instance_types = ["t4g.large"]
    ami_type       = "AL2023_ARM_64_STANDARD" # t4g is Graviton/ARM — must match, or CreateNodegroup rejects it
    disk_size      = 100
    labels = {
      nodegroup  = "observability"
      WorkerType = "ON_DEMAND"
    }
    taints = {
      # terraform-aws-modules/eks/aws expects AWS's screaming-case enum here
      # (NO_SCHEDULE/NO_EXECUTE/PREFER_NO_SCHEDULE), not Kubernetes' own
      # PascalCase — CreateNodegroup rejects "NoSchedule".
      observability = { key = "observability", value = "true", effect = "NO_SCHEDULE" }
    }
  }
}

# All eks-blueprints-addons enabled except karpenter (enable_karpenter is
# hardcoded false in eks-cluster.tf — not controllable via this var).
eks_blueprints_addons = {
  enable_cluster_autoscaler              = true
  enable_aws_efs_csi_driver              = true
  enable_cluster_proportional_autoscaler = true
  enable_metrics_server                  = true
  enable_aws_load_balancer_controller    = true
  enable_external_secrets                = true
}
